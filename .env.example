# Required for admin login
ADMIN_PASSWORD=change-me

# Required for Telegram checkout notifications
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Optional but recommended for live product management + order storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_STORAGE_BUCKET=lmajhol-products

# Optional public site URL for future sharing / metadata
NEXT_PUBLIC_SITE_URL=https://your-site.netlify.app
